<Window
    x:Class="RoboCopyGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:RoboCopyGUI"
    mc:Ignorable="d"
    Title="WinUI 3 File Copier">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          RowDefinitions="Auto, *">

        <!-- Custom title bar: drawn by us so it follows the chosen theme.
             ExtendsContentIntoTitleBar=true is set in code-behind. -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="32"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              ColumnDefinitions="Auto, *, Auto">
            <FontIcon Glyph="&#xE8B7;"
                      FontSize="14"
                      Margin="12,0,8,0"
                      VerticalAlignment="Center"/>
            <TextBlock x:Name="AppTitleText"
                       Grid.Column="1"
                       Text="WinUI 3 File Copier"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       TextTrimming="CharacterEllipsis"/>
            <!-- right column reserved by Windows for the min/max/close caption buttons -->
        </Grid>

        <!-- Body: scroll vertically when window is shorter than content so nothing
             gets clipped at low resolutions. -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,12,20,16">
            <Grid RowDefinitions="Auto, *, Auto, Auto, Auto"
                  MinHeight="420">

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,12">
                <TextBlock Text="File Transfer Utility"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="Drag and drop sources and select a destination."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.7"/>
            </StackPanel>

            <Border x:Name="DropArea"
                    Grid.Row="1"
                    MinHeight="160"
                    Background="Transparent"
                    BorderBrush="{ThemeResource SystemControlDisabledAccentConfigurableBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    AllowDrop="True"
                    DragOver="DropArea_DragOver"
                    Drop="DropArea_Drop">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Layer 1: list (always present, fills the area when there are items) -->
                    <ListView x:Name="SourceListView"
                              Grid.Row="0"
                              ItemsSource="{x:Bind SourceItems, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              Margin="6"
                              Background="Transparent"
                              BorderThickness="0"
                              IsTabStop="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:SourceItem">
                                <Grid ColumnDefinitions="*, Auto, Auto"
                                      Padding="6,4">
                                    <TextBlock Text="{x:Bind Path}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               Opacity="{x:Bind PathOpacity, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               ToolTipService.ToolTip="{x:Bind StatusToolTip, Mode=OneWay}"/>
                                    <FontIcon Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                              Grid.Column="1"
                                              FontSize="16"
                                              Margin="0,0,4,0"
                                              Foreground="{x:Bind StatusBrush, Mode=OneWay}"
                                              ToolTipService.ToolTip="{x:Bind StatusToolTip, Mode=OneWay}"/>
                                    <Button Grid.Column="2"
                                            Click="RemoveItem_Click"
                                            Visibility="{x:Bind RemoveVisibility, Mode=OneWay}"
                                            Padding="6,2"
                                            MinWidth="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTipService.ToolTip="Remove from queue">
                                        <FontIcon Glyph="&#xE894;"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Layer 2: drop hint, on top, hit-test invisible so the list still
                         receives clicks. Collapsed (not just dimmed) once the queue has
                         items so it doesn't reserve vertical space at low resolutions. -->
                    <StackPanel x:Name="DropHintPanel"
                                Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="8"
                                IsHitTestVisible="False">
                        <FontIcon Glyph="&#xE8B7;"
                                  FontSize="56"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Drop Files or Folders Here"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0"
                          ColumnDefinitions="Auto, Auto, *, Auto">
                        <Button x:Name="AddFilesBtn"
                                Content="Add Files…"
                                Click="AddFiles_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="AddFolderBtn"
                                Grid.Column="1"
                                Content="Add Folder…"
                                Click="AddFolder_Click"/>
                        <Button x:Name="ClearListBtn"
                                Grid.Column="3"
                                Content="Clear list"
                                Click="ClearSources_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="0,16,0,0"
                        Spacing="8">
                <TextBlock Text="Destination Path"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnDefinitions="*, Auto">
                    <ComboBox x:Name="DestPathCombo"
                              IsEditable="True"
                              PlaceholderText="Select or type a destination folder..."
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              TextSubmitted="DestPathCombo_TextSubmitted"
                              SelectionChanged="DestPathCombo_SelectionChanged"/>
                    <Button x:Name="BrowseDestBtn"
                            Grid.Column="1"
                            Content="Browse"
                            Click="SelectDest_Click"
                            Margin="10,0,0,0"/>
                </Grid>

                <CheckBox x:Name="DeleteSourceCheck"
                          Content="Delete source files after successful copy (Move mode)"
                          Checked="DeleteSourceCheck_Changed"
                          Unchecked="DeleteSourceCheck_Changed"/>

                <!-- Three notification toggles. -->
                <Grid ColumnDefinitions="Auto, Auto, *"
                      ColumnSpacing="20">
                    <CheckBox x:Name="NotifyOnDoneCheck"
                              Content="Toast on completion"
                              Checked="NotificationToggles_Changed"
                              Unchecked="NotificationToggles_Changed"/>
                    <CheckBox x:Name="PlaySoundCheck"
                              Grid.Column="1"
                              Content="Play sound"
                              Checked="NotificationToggles_Changed"
                              Unchecked="NotificationToggles_Changed"/>
                    <CheckBox x:Name="ShowNetCheck"
                              Grid.Column="2"
                              Content="Show network throughput"
                              Checked="NotificationToggles_Changed"
                              Unchecked="NotificationToggles_Changed"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, Auto, *"
                      ColumnSpacing="12">
                    <TextBlock Text="Parallel small-file copies:"
                               VerticalAlignment="Center"/>
                    <NumberBox x:Name="ParallelSmallBox"
                               Grid.Column="1"
                               Minimum="1"
                               Maximum="16"
                               SmallChange="1"
                               LargeChange="2"
                               SpinButtonPlacementMode="Inline"
                               ValueChanged="ParallelSmallBox_ValueChanged"
                               Width="120"/>
                    <TextBlock Grid.Column="2"
                               Text="(1 = sequential. Threshold: 10 MiB)"
                               Foreground="{ThemeResource SystemControlPlaceholderTextForegroundBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, *"
                      ColumnSpacing="12">
                    <TextBlock Text="On conflict:"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="ConflictPolicyCombo"
                              Grid.Column="1"
                              SelectionChanged="ConflictPolicyCombo_SelectionChanged"
                              MinWidth="220">
                        <ComboBoxItem Content="Overwrite existing"
                                      Tag="Overwrite"/>
                        <ComboBoxItem Content="Skip if destination exists"
                                      Tag="Skip"/>
                        <ComboBoxItem Content="Skip if size + time match"
                                      Tag="SkipIfSame"/>
                        <ComboBoxItem Content="Rename (append (1), (2)…)"
                                      Tag="Rename"/>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Margin="0,12,0,12"
                        Spacing="4">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPlaceholderTextForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="OverallProgressText"
                               Grid.Column="1"
                               Text=""
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPlaceholderTextForegroundBrush}"/>
                </Grid>
                <TextBlock x:Name="NetText"
                           Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlPlaceholderTextForegroundBrush}"
                           Visibility="Collapsed"/>
                <ProgressBar x:Name="CopyProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False"
                             Height="4"
                             ToolTipService.ToolTip="Current file"/>
                <ProgressBar x:Name="OverallProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False"
                             Height="8"
                             ToolTipService.ToolTip="Overall progress"/>
            </StackPanel>

            <Grid Grid.Row="4"
                  ColumnDefinitions="Auto, *, Auto, Auto, Auto">
                <Button x:Name="ThemeBtn"
                        Click="ThemeBtn_Click"
                        HorizontalAlignment="Left"
                        ToolTipService.ToolTip="Toggle theme">
                    <FontIcon x:Name="ThemeIcon"
                              Glyph="&#xEC46;"
                              FontSize="16"/>
                </Button>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="12">
                    <Button x:Name="StartBtn"
                            Content="Start Copy"
                            Click="StartBtn_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Start (F5)"
                            Width="100">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5"/>
                        </Button.KeyboardAccelerators>
                    </Button>
                    <Button x:Name="PauseBtn"
                            Content="Pause"
                            Click="PauseBtn_Click"
                            IsEnabled="False"
                            ToolTipService.ToolTip="Pause / Resume (F6)"
                            Width="100">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F6"/>
                        </Button.KeyboardAccelerators>
                    </Button>
                    <Button x:Name="CancelBtn"
                            Content="Cancel"
                            Click="CancelBtn_Click"
                            IsEnabled="False"
                            ToolTipService.ToolTip="Cancel (Esc)"
                            Width="100">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Escape"/>
                        </Button.KeyboardAccelerators>
                    </Button>
                </StackPanel>
            </Grid>

            </Grid>
        </ScrollViewer>
        <!-- /body grid -->

    </Grid>
</Window>